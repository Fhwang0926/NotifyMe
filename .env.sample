# NotifyMe 환경 변수 (복사 후 .env 로 저장)
#   cp .env.sample .env   (Linux/Mac)
#   copy .env.sample .env (Windows)
# 이 파일(.env.sample)만 저장소에 포함하세요. 실제 값이 들어간 .env 는 절대 커밋하지 마세요.

# 크롤러 SSL 검증 (기본: 비활성화). 1 이면 인증서 검증함 (권장하지 않음, 일부 사이트 오류)
# CRAWLER_VERIFY_SSL=0

# 수집 후 키워드 필터 적용 (1 = 적용)
# CRAWLER_KEYWORD_FILTER=0

# HTTP 실패 시 Puppeteer 폴백 사용 (기본: 사용). 폴백 끄려면 safeGet 옵션 skipPuppeteerFallback: true
# (선택) Puppeteer 페이지 로드 타임아웃(ms). 기본 30000
# CRAWLER_PUPPETEER_TIMEOUT_MS=30000

# 대시보드 웹 서버 포트 (0.0.0.0:80 기본). 변경 시 예: WEB_PORT=8080
WEB_PORT=80

# ─── MariaDB (필수) ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=notifyme
# 연결 풀 (선택). 미설정 시 기본값 사용 — 요청마다 새 연결하지 않고 풀 공유
# DB_POOL_MAX=10
# DB_POOL_MIN=0
# DB_POOL_ACQUIRE_MS=60000
# DB_POOL_IDLE_MS=10000

# ─── API (필수) ───
# 공공데이터포털 K-Startup API 키 (미설정 시 서버 기동 불가)
# 발급: https://www.data.go.kr/ → "창업진흥원_K-Startup(사업소개,사업공고,콘텐츠 등)_조회서비스"
K_STARTUP_API_KEY=your_service_key_here
# (선택) 사업공고 API. 미설정 시 getAnnouncementInformation01 사용
# DATA_GO_KR_BUSINESS_API_URL=https://apis.data.go.kr/B552735/kisedKstartupService01/getAnnouncementInformation01
# (선택) 사업 정보 API. 미설정 시 getBusinessInformation01 사용
# DATA_GO_KR_GET_BUSINESS_INFO_URL=https://apis.data.go.kr/B552735/kisedKstartupService01/getBusinessInformation01
# (선택) 사업 소개 정보 API. 미설정 시 getSuptBizIntro01 사용 (예산·규모·수행기관·문의처 등)
# DATA_GO_KR_SUPT_BIZ_INTRO_URL=https://apis.data.go.kr/B552735/kisedKstartupService01/getSuptBizIntro01
# getAnnouncementInformation01: 한 페이지 결과 수 (기본 1000, 문서 기준 최대 10000)
# K_STARTUP_ANNOUNCE_PER_PAGE=1000
# 모집진행여부 조건: Y=모집중만, N=모집마감만, 비우면 전체
# K_STARTUP_ANNOUNCE_RCRT_PRGS_YN=
# getAnnouncementInformation01 추가 cond (선택). 예: 행사·네트워크, 전국, 예비창업자
# K_STARTUP_ANNOUNCE_COND_INTG_PBANC_YN=N
# K_STARTUP_ANNOUNCE_COND_SUPT_BIZ_CLSFC=행사ㆍ네트워크
# K_STARTUP_ANNOUNCE_COND_SUPT_REGIN=전국
# K_STARTUP_ANNOUNCE_COND_BIZ_ENYY=예비창업자
# getBusinessInformation01: 연도 조건 (stdt). 기본 현재 연도
# K_STARTUP_BUSINESS_INFO_STDT=2026

# ─── 메일 발송 Nodemailer/SMTP (선택) ───
# 데이터 갱신 시 구독자에게 메일 알림 발송
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your_smtp_app_password_here
SMTP_FROM=NotifyMe <your-email@example.com>
SMTP_SECURE=0
